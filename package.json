{
  "name": "skillforge",
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "private": true,
  "description": "SkillForge — AI Agent Platform with Skill Marketplace",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "bash scripts/dev.sh",
    "infra:up": "docker compose up -d postgres redis minio && docker compose up -d docker-socket-proxy",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis minio",
    "sandbox:build": "cd services/sandbox && go build -o ../../.bin/sandbox ./cmd/sandbox/",
    "sandbox:dev": "export $(grep -v '^#' .env.local | xargs) && SANDBOX_SERVER_PORT=8194 SANDBOX_SERVER_API_KEY=${SANDBOX_API_KEY:-sk-sandbox-dev} SANDBOX_DOCKER_HOST=tcp://localhost:2375 .bin/sandbox",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "db:migrate": "pnpm --filter @skillforge/core migration:run",
    "db:generate": "pnpm --filter @skillforge/core migration:generate",
    "db:revert": "pnpm --filter @skillforge/core migration:revert",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
