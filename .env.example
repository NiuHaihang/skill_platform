# ─────────────────────────────────────────────────────────────
# SkillForge — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://skillforge:skillforge_dev@localhost:5432/skillforge_db
POSTGRES_DB=skillforge_db
POSTGRES_USER=skillforge
POSTGRES_PASSWORD=skillforge_dev

# ── Redis ────────────────────────────────────────────────────
# REDIS_PASSWORD is used both in the Redis URL and by docker-compose redis healthcheck.
# Must match the redis service's REDIS_PASSWORD value in docker-compose.yml.
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379

# ── JWT ──────────────────────────────────────────────────────
# IMPORTANT: Generate strong random secrets in production!
# Use: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_64_IN_PRODUCTION
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_USE_OPENSSL_RAND_HEX_64
JWT_REFRESH_EXPIRES_IN=7d

# ── MinIO ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=skillforge_minio
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=skillforge-assets

# ── Sandbox Service ──────────────────────────────────────────
SANDBOX_API_URL=http://localhost:8194
SANDBOX_API_KEY=sk-sandbox-dev-CHANGE_ME
SANDBOX_TIMEOUT_MS=120000

# ── LLM Providers (fill in your keys) ───────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
# Override to use a proxy or local mirror compatible with DeepSeek API
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama — local inference (https://ollama.com)
# No API key needed for local usage.
# Requires Ollama ≥ v0.1.24 for /v1 OpenAI-compatible endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Example model values: llama3:8b, qwen2:7b, mistral:latest, phi3:mini
# Use the "ollama/" prefix in requests: e.g. model="ollama/llama3:8b"

# Default models
LLM_DEFAULT_MODEL=gpt-4o
LLM_ROUTER_MODEL=gpt-4o-mini

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_SHORT_LIMIT=20
THROTTLE_MEDIUM_LIMIT=100
THROTTLE_LONG_LIMIT=1000
